<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
	xmlns:g="urn:import:com.google.gwt.user.client.ui">
	<g:HTMLPanel width="800px" styleName="creationRootPanel">
		<g:HTMLPanel ui:field="htmlPanelSorry" visible="false">
			問題作成は30回以上プレイされた方のみに限定させて頂いております。
			申し訳ありません。
			30回以上プレイされてこの表示が表示されている場合はF5を押して再読み込みを行ってください。
			よろしくお願い致します。
		</g:HTMLPanel>
		<g:HTMLPanel ui:field="htmlRequireGooglePlusLogin"
			visible="false">
			問題作成はGoogleアカウント連携（OIDC）をした方のみに限定させていただいております。
			申し訳ありません。
			Googleアカウント連携（OIDC）は「設定」→「ユーザーコード」から行うことができます。
			Googleアカウント連携（OIDC）をされた方でこの表示が表示されている場合はF5を押して再読み込みを行ってください。
			よろしくお願い致します。
		</g:HTMLPanel>
		<g:HTMLPanel ui:field="htmlPanelMain" visible="false">
			<g:HTMLPanel styleName="creationWizard">
				<g:HTMLPanel styleName="creationIntroCard">
					<g:Label styleName="creationIntroCardTitle" text="作成ガイド" />
					<g:HTML styleName="creationIntroCardBody">
						問題ジャンルの偏りを減らすため、問題数の少ないジャンルへの投稿にご協力ください。<br />
						投稿後は正解率統計で自作問題の状態をご確認いただき、指摘フラグが付いた場合は早めの修正をお願いします。
					</g:HTML>
					<a href="creation-guideline.html" target="_blank" rel="noopener noreferrer"
						class="creationGuidelineLink">問題作成ガイドラインを見る（新規タブ）</a>
				</g:HTMLPanel>
				<g:HTMLPanel styleName="creationWizardUtilityBar">
					<g:Button ui:field="buttonNewProblem" text="入力内容をリセットする"
						styleName="creationButtonSecondary" />
				</g:HTMLPanel>
				<g:HorizontalPanel styleName="creationWizardSteps">
					<g:Label ui:field="labelStep1" text="1. モード選択" />
					<g:Label ui:field="labelStep2" text="2. 基本情報" />
					<g:Label ui:field="labelStep3" text="3. 問題文" />
					<g:Label ui:field="labelStep4" text="4. 解答設定" />
					<g:Label ui:field="labelStep5" text="5. 確認" />
				</g:HorizontalPanel>
				<g:HTML ui:field="htmlStepErrorSummary"
					styleName="creationStepErrorSummary" />
				<g:HTMLPanel ui:field="panelWizardFormHost"
					styleName="creationWizardStepPanel">
					<g:SimplePanel ui:field="panelProblemForm" />
				</g:HTMLPanel>
				<g:HTMLPanel ui:field="panelStep1" styleName="creationWizardStepPanel">
					<h2>モード選択</h2>
					<g:HTMLPanel ui:field="panelCreationModeCards" styleName="creationModeCards">
						<g:HTMLPanel ui:field="panelCreationModeNew" styleName="creationModeCard">
							<g:Label styleName="creationModeCardTitle" text="新規作成" />
							<g:Label styleName="creationModeCardDescription"
								text="まっさらな状態から新しい問題を作成します。" />
							<g:Button ui:field="buttonSelectNewMode" text="このモードで開始"
								styleName="creationButtonSecondary" />
						</g:HTMLPanel>
						<g:HTMLPanel ui:field="panelCreationModeEdit" styleName="creationModeCard">
							<g:Label styleName="creationModeCardTitle" text="既存を修正" />
							<g:Label styleName="creationModeCardDescription"
								text="問題番号を読み込み、同じ問題番号で更新します。" />
							<g:Button ui:field="buttonSelectEditMode" text="このモードで開始"
								styleName="creationButtonSecondary" />
						</g:HTMLPanel>
						<g:HTMLPanel ui:field="panelCreationModeClone" styleName="creationModeCard">
							<g:Label styleName="creationModeCardTitle" text="コピーして新規作成" />
							<g:Label styleName="creationModeCardDescription"
								text="既存問題を読み込み、新規問題として投稿します。" />
							<g:Button ui:field="buttonSelectCloneMode" text="このモードで開始"
								styleName="creationButtonSecondary" />
						</g:HTMLPanel>
					</g:HTMLPanel>
					<g:Label ui:field="labelCurrentCreationMode"
						styleName="creationModeCurrentLabel" />
					<g:HTMLPanel ui:field="panelProblemLoader"
						styleName="creationProblemLoaderPanel">
						<g:Label text="既存問題を読み込む" styleName="creationProblemLoaderTitle" />
						<g:Label text="問題番号を入力して読み込んでください。修正・コピー操作は読み込み後に利用できます。"
							styleName="creationProblemLoaderDescription" />
						<g:HorizontalPanel>
							<g:TextBox ui:field="textBoxGetProblem" width="200px" />
							<g:Button ui:field="buttonGetProblem" text="問題を読み込む"
								styleName="creationButtonPrimary"
								title="投稿済みの問題を読み込み、修正して更新できます。" />
							<g:Button ui:field="buttonCopyProblem" text="問題をコピーして読み込む"
								styleName="creationButtonPrimary"
								title="投稿済みの問題を読み込み、複製して新規問題として投稿できます。" />
						</g:HorizontalPanel>
					</g:HTMLPanel>
				</g:HTMLPanel>
				<g:HTMLPanel ui:field="panelStep2" styleName="creationWizardStepPanel"
					visible="false">
					<h2>基本情報</h2>
					ジャンル・出題形式・ランダムフラグ・問題作成者を入力してください。
				</g:HTMLPanel>
				<g:HTMLPanel ui:field="panelStep3" styleName="creationWizardStepPanel"
					visible="false">
					<h2>問題文</h2>
					問題文を入力してください。
				</g:HTMLPanel>
				<g:HTMLPanel ui:field="panelStep4" styleName="creationWizardStepPanel"
					visible="false">
					<h2>解答設定</h2>
					<g:VerticalPanel ui:field="panelWarning" />
					<g:HTML ui:field="htmlTypeCaution" />
					<g:SimplePanel ui:field="panelChangeHistory" />
					<g:HTMLPanel ui:field="htmlPanelWrongAnswer" styleName="creationWrongAnswerSection"
						visible="false">
						<h1 class="creationWrongAnswerTitle">誤答例</h1>
						<g:SimplePanel ui:field="panelWrongAnswer" />
					</g:HTMLPanel>
					<g:HTMLPanel ui:field="htmlPanelBbs" visible="false">
						<h1>問題掲示板</h1>
						<g:SimplePanel ui:field="panelBbs" />
					</g:HTMLPanel>
				</g:HTMLPanel>
				<g:HTMLPanel ui:field="panelStep5" styleName="creationWizardStepPanel"
					visible="false">
					<h2>確認</h2>
					<g:HTMLPanel styleName="creationSummaryCards">
						<g:HTMLPanel ui:field="panelStep4CardBasic"
							styleName="creationSummaryCard">
							<g:HTMLPanel styleName="creationSummaryCardHeader">
								<g:Label styleName="creationSummaryCardTitle" text="基本情報" />
								<g:HTMLPanel styleName="creationSummaryCardHeaderActions">
									<g:Button ui:field="buttonToggleStep1Detail" text="詳細を開く"
										styleName="creationButtonSecondary creationSummaryCardAction" />
									<g:Button ui:field="buttonBackToStep1FromSummary" text="編集へ戻る"
										styleName="creationButtonSecondary creationSummaryCardAction" />
								</g:HTMLPanel>
							</g:HTMLPanel>
							<g:HTML ui:field="htmlStep4SummaryBasic" styleName="creationSummaryText creationFormPreviewField" />
							<g:HTML ui:field="htmlStep4DetailBasic" styleName="creationSummaryDetail creationFormPreviewDetail"
								visible="false" />
						</g:HTMLPanel>
						<g:HTMLPanel ui:field="panelStep4CardQuestion"
							styleName="creationSummaryCard">
							<g:HTMLPanel styleName="creationSummaryCardHeader">
								<g:Label styleName="creationSummaryCardTitle" text="問題文" />
								<g:HTMLPanel styleName="creationSummaryCardHeaderActions">
									<g:Button ui:field="buttonToggleStep2Detail" text="詳細を開く"
										styleName="creationButtonSecondary creationSummaryCardAction" />
									<g:Button ui:field="buttonBackToStep2FromSummary" text="編集へ戻る"
										styleName="creationButtonSecondary creationSummaryCardAction" />
								</g:HTMLPanel>
							</g:HTMLPanel>
							<g:HTML ui:field="htmlStep4SummaryQuestion"
								styleName="creationSummaryText creationFormPreviewField" />
							<g:HTML ui:field="htmlStep4DetailQuestion" styleName="creationSummaryDetail creationFormPreviewDetail"
								visible="false" />
						</g:HTMLPanel>
						<g:HTMLPanel ui:field="panelStep4CardAnswer"
							styleName="creationSummaryCard">
							<g:HTMLPanel styleName="creationSummaryCardHeader">
								<g:Label styleName="creationSummaryCardTitle" text="解答設定" />
								<g:HTMLPanel styleName="creationSummaryCardHeaderActions">
									<g:Button ui:field="buttonToggleStep3Detail" text="詳細を開く"
										styleName="creationButtonSecondary creationSummaryCardAction" />
									<g:Button ui:field="buttonBackToStep3FromSummary" text="編集へ戻る"
										styleName="creationButtonSecondary creationSummaryCardAction" />
								</g:HTMLPanel>
							</g:HTMLPanel>
							<g:HTML ui:field="htmlStep4SummaryAnswer" styleName="creationSummaryText creationFormPreviewField" />
							<g:HTML ui:field="htmlStep4DetailAnswer" styleName="creationSummaryDetail creationFormPreviewDetail"
								visible="false" />
						</g:HTMLPanel>
					</g:HTMLPanel>
					<g:HTMLPanel ui:field="panelSimilarSection" styleName="creationSimilarSection" visible="false">
						<g:Label styleName="creationSimilarSectionTitle" text="類似問題候補" />
						<g:HTML ui:field="htmlSimilarLead" styleName="creationSimilarLead" visible="false">
							入力内容に近い問題候補です。重複投稿を防ぐため、問題文・解答・形式を確認してください。
						</g:HTML>
						<g:SimplePanel ui:field="panelSimilar" />
					</g:HTMLPanel>
					<g:HTML ui:field="htmlSampleLead" styleName="creationPreviewLead" visible="false">
						以下は、実際の出題画面に近い表示です。
					</g:HTML>
					<g:SimplePanel ui:field="panelSample" />
					<g:HorizontalPanel>
						<g:Button ui:field="buttonMoveToVerification"
							text="送信確認画面に移動する" styleName="creationButtonPrimary" />
						<g:Button ui:field="buttonSendProblem" text="問題を送信する"
							visible="false" styleName="creationButtonSecondary"
							title="似たような問題が無い事を確認しましたか？" />
					</g:HorizontalPanel>
				</g:HTMLPanel>
				<g:HorizontalPanel styleName="creationWizardFooter">
					<g:Button ui:field="buttonPrevStep" text="戻る"
						styleName="creationButtonSecondary creationWizardBackButton" />
					<g:Button ui:field="buttonNextStep" text="次へ"
						styleName="creationButtonPrimary creationWizardNextButton" />
				</g:HorizontalPanel>
			</g:HTMLPanel>
		</g:HTMLPanel>
		<g:HTMLPanel ui:field="htmlPanelDone" visible="false">
			問題を送信しました。問題番号は
			<g:Label ui:field="labelProblemId" />
			です。
			<g:Button ui:field="buttonNextProblem" text="続けて問題を作成する"
				styleName="creationButtonPrimary" />
		</g:HTMLPanel>
	</g:HTMLPanel>
</ui:UiBinder>
