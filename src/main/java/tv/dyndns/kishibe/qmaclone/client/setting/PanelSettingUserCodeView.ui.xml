<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
	xmlns:g="urn:import:com.google.gwt.user.client.ui">
	<g:HTMLPanel styleName="settingUserCodeRoot">
		<g:HTMLPanel styleName="settingUserCodeCard">
			<g:Label styleName="settingUserCodeCardTitle" text="ユーザーコード変更" />
			<g:HTML styleName="settingUserCodeLead">
				ユーザーコードを変更できます。ユーザーコードを控えておくと、どのブラウザからでも同じプレイヤー情報でプレイできます。<br/>
				ユーザーコードの変更後は、F5を押してページをリロードしてください。
			</g:HTML>
			<g:HorizontalPanel styleName="settingUserCodeActionRow">
				<g:TextBox ui:field="textBoxUserCode" width="220px" />
				<g:Button ui:field="buttonSwitchToUserCode" enabled="true"
					styleName="creationButtonPrimary">ユーザーコードを切り替える</g:Button>
			</g:HorizontalPanel>
			<g:HTML ui:field="htmlInvalidUserCode" visible="false"
				styleName="settingUserCodeMessage settingUserCodeMessageError">ユーザーコードが正しく入力されていません。またはユーザーコードが見つかりません。</g:HTML>
		</g:HTMLPanel>

		<g:HTMLPanel styleName="settingUserCodeCard">
			<g:Label styleName="settingUserCodeCardTitle" text="Googleアカウント連携（OIDC）" />
			<g:HTML styleName="settingUserCodeLead">
				QMACloneユーザーコードをGoogleアカウントに連携させると、どのブラウザからでも共通のプレイヤー情報でプレイできます。<br />
				複数のユーザーコードを連携する場合は、先に上の「ユーザーコード変更」で切り替えてから連携してください。<br />
				ポップアップをブロックしている場合は許可してください。
			</g:HTML>
			<g:HorizontalPanel styleName="settingUserCodeActionRow">
				<g:Button ui:field="buttonConnect" visible="false"
					styleName="creationButtonPrimary">現在のユーザーコードをGoogleアカウントに紐づける</g:Button>
			</g:HorizontalPanel>
			<g:HTML ui:field="htmlAlreadyConnected" visible="false"
				styleName="settingUserCodeMessage">すでに連携させています。新たに連携させる必要はありません。</g:HTML>
			<g:HTML ui:field="htmlConnected" visible="false"
				styleName="settingUserCodeMessage">このGoogleアカウントに紐づくQMACloneユーザーコードは見つかりませんでした。必要であれば「現在のユーザーコードをGoogleアカウントに紐づける」を実行してください。</g:HTML>

			<g:HTMLPanel styleName="settingUserCodeLinkedListCard">
				<g:Label styleName="settingUserCodeLinkedListTitle" text="連携済みユーザーコード" />
				<g:VerticalPanel ui:field="panelUserCodeList" styleName="settingUserCodeLinkedList" />
			</g:HTMLPanel>

			<g:HorizontalPanel styleName="settingUserCodeActionRow">
				<g:Button ui:field="buttonShowUserCodeList" visible="false"
					styleName="creationButtonSecondary">Googleログインして紐づけ済みユーザーコードを表示する</g:Button>
			</g:HorizontalPanel>
			<g:HorizontalPanel styleName="settingUserCodeActionRow">
				<g:Button ui:field="buttonSwitchToConnectedUserCode" visible="false"
					styleName="creationButtonSecondary">選択したユーザーコードに切り替える</g:Button>
			</g:HorizontalPanel>
			<g:HorizontalPanel styleName="settingUserCodeActionRow">
				<g:Button ui:field="buttonDisconnectUserCode" visible="false"
					styleName="creationButtonSecondary">選択したユーザーコードとGoogleアカウントの紐づけを解除する</g:Button>
			</g:HorizontalPanel>
		</g:HTMLPanel>
	</g:HTMLPanel>
</ui:UiBinder> 
