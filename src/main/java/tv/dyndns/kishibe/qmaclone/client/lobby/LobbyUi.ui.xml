<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
  xmlns:g="urn:import:com.google.gwt.user.client.ui"
  xmlns:k="urn:import:tv.dyndns.kishibe.qmaclone.client.ui">
  <ui:style>
  .lobbyRoot {
    width: 100%;
    max-width: 980px;
    min-height: 70vh;
    margin: 16px auto 0 auto;
    padding: 18px;
    border: 1px solid #2f537a;
    border-radius: 14px;
    background: linear-gradient(180deg, #122c4d 0%, #0c2240 100%);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: #eaf4ff;
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.35);
  }

  .lobbyStatusRow {
    text-align: center;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid #355e88;
    background: rgba(8, 20, 38, 0.55);
    font-size: 24px;
    font-weight: bold;
    color: #dcf2ff;
  }

  .lobbyTopSection {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .lobbySummaryLine {
    text-align: center;
    font-size: 18px;
    color: #bcd4ea;
  }

  .lobbyButtonGrid {
    width: 100%;
    border-collapse: separate;
    border-spacing: 10px 10px;
  }

  .lobbyStartButton {
    width: 100%;
    min-width: 260px;
    height: 62px;
    border: 1px solid #5ea7cc;
    border-radius: 10px;
    background: linear-gradient(180deg, #1b4a72 0%, #123656 100%);
    color: #e7f7ff;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    transition: box-shadow 180ms ease, transform 180ms ease, border-color 180ms ease;
  }

  .lobbyStartButton:hover {
    border-color: #69deff;
    box-shadow: 0 0 18px rgba(84, 216, 255, 0.45);
    transform: translateY(-1px);
  }

  .lobbyStartButton:active {
    transform: translateY(1px);
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.35);
  }

  .lobbyStartButton:disabled {
    border-color: #6f8ca7;
    background: linear-gradient(180deg, #57708a 0%, #445c73 100%);
    color: #d9e7f4;
    cursor: not-allowed;
    box-shadow: none;
    transform: none;
  }

  .lobbyStartButton:focus {
    outline: 2px solid #77e4ff;
    outline-offset: 2px;
  }

  .lobbySubButton {
    border: 1px solid #4f78a5;
    border-radius: 6px;
    background: #0e2746;
    color: #dff1ff;
    transition: background-color 140ms ease, border-color 140ms ease, box-shadow 140ms ease,
      transform 90ms ease;
  }

  .lobbySubButton:hover {
    background: #13345d;
    border-color: #69deff;
    box-shadow: 0 0 0 2px rgba(105, 222, 255, 0.18);
  }

  .lobbySubButton:active {
    transform: translateY(1px);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .lobbySubButton:disabled {
    background: #edf2f7;
    border-color: #c7d4e0;
    color: #7e91a5;
    cursor: not-allowed;
    box-shadow: none;
    transform: none;
  }

  .lobbyConditionCard {
    border: 1px solid #355e88;
    border-radius: 10px;
    padding: 12px;
    background: rgba(8, 20, 38, 0.42);
  }

  .lobbyPrimaryConditionCard {
    border-color: #4f78a5;
    background: rgba(12, 30, 52, 0.58);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.2);
  }

  .lobbySettingsSection {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lobbySectionTitle {
    font-size: 15px;
    font-weight: bold;
    color: #d9ecff;
    letter-spacing: 0.06em;
    padding: 2px 4px;
  }

  .lobbyConditionGrid {
    width: 100%;
    border-collapse: separate;
    border-spacing: 8px 6px;
  }

  .lobbyLabelCell {
    text-align: right;
    width: 140px;
    color: #b9d3eb;
    white-space: nowrap;
  }

  .lobbyValueCell {
    text-align: left;
  }

  .lobbyValueCell > .lobbySubButton {
    margin-right: 6px;
  }

  .lobbyValueCell select,
  .lobbyValueCell input[type="text"] {
    width: 100%;
    max-width: 300px;
    min-height: 30px;
    box-sizing: border-box;
    border: 1px solid #4f78a5;
    border-radius: 6px;
    background: #0e2746;
    color: #e8f2ff;
    padding: 4px 8px;
  }

  .lobbyValueCell select:focus,
  .lobbyValueCell input[type="text"]:focus {
    outline: 2px solid #77e4ff;
    outline-offset: 1px;
    border-color: #77e4ff;
  }

  .lobbyPublicEventCheck {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    color: #d7e9ff;
    white-space: nowrap;
    line-height: 1.2;
  }

  .lobbyPublicEventCheck label {
    white-space: nowrap;
  }

  .lobbyPublicEventCheck input[type="checkbox"] {
    margin: 0;
    accent-color: #5db3ff;
  }

  .lobbySummaryBottom {
    margin-top: auto;
    width: 100%;
    text-align: center;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid #355e88;
    background: rgba(8, 20, 38, 0.55);
    color: #d5ebff;
    font-size: 22px;
    font-weight: bold;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px 14px;
  }

  .lobbySummaryMetric {
    white-space: nowrap;
  }

  .lobbyPlayerHistory {
    display: none;
  }

  .lobbyDetailSettingsGrid {
    table-layout: fixed;
  }

  .lobbyDetailSettingsGrid col.lobbyDetailLabelCol {
    width: 18%;
  }

  .lobbyDetailSettingsGrid col.lobbyDetailValueCol {
    width: 32%;
  }
  </ui:style>
  <g:HTMLPanel styleName="{style.lobbyRoot}">
    <g:HTMLPanel styleName="{style.lobbyStatusRow}">
      全体対戦待機中:
      <span ui:field="spanWaiting">0</span>
      人
    </g:HTMLPanel>

    <g:HTMLPanel styleName="{style.lobbyTopSection}">
      <g:HTMLPanel styleName="{style.lobbySummaryLine}">
        ジャンル: [ノンジャンル] / 形式: [ランダム] / 難易度: 易問を出題する
      </g:HTMLPanel>

      <table class="{style.lobbyButtonGrid}">
        <tr>
          <td>
            <g:Button ui:field="buttonGameVsCom" text="COM対戦"
              styleName="{style.lobbyStartButton}" />
          </td>
          <td>
            <g:Button ui:field="buttonGameAllClass" text="全体対戦"
              styleName="{style.lobbyStartButton}" />
          </td>
        </tr>
        <tr>
          <td>
            <g:Button ui:field="buttonGameEvent" text="イベント対戦"
              styleName="{style.lobbyStartButton}" />
          </td>
          <td>
            <g:Button ui:field="buttonGameTheme" text="テーマモード"
              styleName="{style.lobbyStartButton}" />
          </td>
        </tr>
      </table>

      <g:HTMLPanel styleName="{style.lobbySettingsSection}">
        <g:HTMLPanel styleName="{style.lobbySectionTitle}">主要設定</g:HTMLPanel>
        <g:HTMLPanel styleName="{style.lobbyConditionCard} {style.lobbyPrimaryConditionCard}">
          <table class="{style.lobbyConditionGrid}">
            <tr>
              <td class="{style.lobbyLabelCell}">ジャンル</td>
              <td class="{style.lobbyValueCell}">
                <k:WidgetMultiItemSelector ui:field="multiItemSelectorGenre" />
              </td>
              <td class="{style.lobbyLabelCell}">出題形式</td>
              <td class="{style.lobbyValueCell}">
                <k:WidgetMultiItemSelector ui:field="multiItemSelectorType" />
              </td>
            </tr>
            <tr>
              <td class="{style.lobbyLabelCell}">難易度</td>
              <td class="{style.lobbyValueCell}">
                <g:ListBox ui:field="listBoxDifficultSelect" />
              </td>
              <td class="{style.lobbyLabelCell}">プレイヤー名</td>
              <td class="{style.lobbyValueCell}">
                <g:TextBox ui:field="textBoxPlayerName" maxLength="8" />
              </td>
            </tr>
          </table>
        </g:HTMLPanel>
      </g:HTMLPanel>

      <g:HTMLPanel styleName="{style.lobbySettingsSection}">
        <g:HTMLPanel styleName="{style.lobbySectionTitle}">詳細設定</g:HTMLPanel>
        <g:HTMLPanel styleName="{style.lobbyConditionCard}">
        <table class="{style.lobbyConditionGrid} {style.lobbyDetailSettingsGrid}">
          <colgroup>
            <col class="{style.lobbyDetailLabelCol}" />
            <col class="{style.lobbyDetailValueCol}" />
            <col class="{style.lobbyDetailLabelCol}" />
            <col class="{style.lobbyDetailValueCol}" />
          </colgroup>
          <tr>
            <td class="{style.lobbyLabelCell}">階級(自己申告)</td>
            <td class="{style.lobbyValueCell}">
              <g:ListBox ui:field="listBoxLevelName" />
              <g:ListBox ui:field="listBoxLevelNumber" />
            </td>
            <td class="{style.lobbyLabelCell}">地域</td>
            <td class="{style.lobbyValueCell}">
              <g:ListBox ui:field="listBoxPrefecture" />
            </td>
          </tr>
          <tr>
            <td class="{style.lobbyLabelCell}">対戦前の挨拶</td>
            <td class="{style.lobbyValueCell}">
              <g:TextBox ui:field="textBoxGreeting" maxLength="10" text="よろしく～！" />
            </td>
            <td class="{style.lobbyLabelCell}">新問設定</td>
            <td class="{style.lobbyValueCell}">
              <g:ListBox ui:field="listBoxNewProblem">
                <g:item>新問と旧問を出題する</g:item>
                <g:item>旧問のみ出題する</g:item>
                <g:item>新問のみ出題する</g:item>
              </g:ListBox>
            </td>
          </tr>
          <tr>
            <td class="{style.lobbyLabelCell}">イベント名</td>
            <td class="{style.lobbyValueCell}">
              <g:TextBox ui:field="textBoxEventName" maxLength="16" />
              <g:Button ui:field="buttonShowEventRooms" text="参照"
                styleName="{style.lobbySubButton}" />
              <g:CheckBox ui:field="checkBoxPublicEvent" text="イベント戦を公開する"
                styleName="{style.lobbyPublicEventCheck}" />
            </td>
            <td class="{style.lobbyLabelCell}">テーマ</td>
            <td class="{style.lobbyValueCell}">
              <g:ListBox ui:field="listBoxTheme" />
            </td>
          </tr>
        </table>
        </g:HTMLPanel>
      </g:HTMLPanel>
    </g:HTMLPanel>

    <g:HTMLPanel styleName="{style.lobbySummaryBottom}">
      <span class="{style.lobbySummaryMetric}">
        レーティング:
        <span ui:field="spanRating">0</span>
        /
      </span>
      <span class="{style.lobbySummaryMetric}">
        平均順位:
        <span ui:field="spanAverageRank">未プレイ</span>
        /
      </span>
      <span class="{style.lobbySummaryMetric}">
        プレイ回数:
        <span ui:field="spanPlayCount">0</span>
        /
      </span>
      <span class="{style.lobbySummaryMetric}">
        直近スコア:
        <span ui:field="spanHighScore">0</span>
        /
      </span>
      <span class="{style.lobbySummaryMetric}">
        平均スコア:
        <span ui:field="spanAverageScore">0</span>
      </span>
    </g:HTMLPanel>

    <g:HTMLPanel styleName="{style.lobbyPlayerHistory}">
      <span ui:field="spanPlayerHistory" />
    </g:HTMLPanel>
  </g:HTMLPanel>
</ui:UiBinder>
