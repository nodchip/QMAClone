<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
	xmlns:g="urn:import:com.google.gwt.user.client.ui">
	<g:HTMLPanel styleName="settingOtherRoot">
		<g:HTMLPanel styleName="settingOtherIntroCard">
			<g:HTML styleName="settingThemeModeTitle">その他設定</g:HTML>
			<g:HTML styleName="settingThemeModeLead settingOtherLead">プレイ中の表示、通信方式、統計登録の動作を調整できます。変更は即時保存されます。</g:HTML>
		</g:HTMLPanel>

		<g:HTMLPanel styleName="settingOtherGrid">
			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">効果音</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonSeOn" name="SE" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonSeOff" name="SE" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:CheckBox ui:field="checkBoxSoundMuted" styleName="settingOtherOption">ミュート</g:CheckBox>
					<g:InlineLabel styleName="settingOtherOption">全体</g:InlineLabel>
					<g:ListBox ui:field="listBoxSoundMaster" />
					<g:InlineLabel styleName="settingOtherOption">UI</g:InlineLabel>
					<g:ListBox ui:field="listBoxSoundUi" />
					<g:InlineLabel styleName="settingOtherOption">ゲーム</g:InlineLabel>
					<g:ListBox ui:field="listBoxSoundGameplay" />
					<g:InlineLabel styleName="settingOtherOption">結果</g:InlineLabel>
					<g:ListBox ui:field="listBoxSoundResult" />
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">ゲーム中のランキング上下変動表示</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonRankingMoveOn" name="RANKING_MOVE" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonRankingMoveOff" name="RANKING_MOVE" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">解答後に解答を隠す</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonHideAnswerOn" name="GROUP_HIDE_ANSWER" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonHideAnswerOff" name="GROUP_HIDE_ANSWER" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">ログイン画面の情報表示</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonShowInfoOn" name="GROUP_SHOW_INFO" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonShowInfoOff" name="GROUP_SHOW_INFO" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">イベント戦の成績を個人戦績に反映</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonReflectEventResultOn" name="GROUP_REFLECT_EVENT_RESULT" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonReflectEventResultOff" name="GROUP_REFLECT_EVENT_RESULT" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">サーバー通信にWebSocketを使用</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonWebSocketDefault" name="GROUP_WEB_SOCKET" styleName="settingOtherOption">初期値</g:RadioButton>
					<g:RadioButton ui:field="radioButtonWebSocketOn" name="GROUP_WEB_SOCKET" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonWebSocketOff" name="GROUP_WEB_SOCKET" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">問題作成時に正解率統計へ自動登録</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonRegisterCreatedProblemOn" name="GROUP_REGISTER_CREATED_PROBLEM" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonRegisterCreatedProblemOff" name="GROUP_REGISTER_CREATED_PROBLEM" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>

			<g:HTMLPanel styleName="settingOtherItem">
				<g:HTML styleName="settingOtherItemTitle">問題指摘時に正解率統計へ自動登録</g:HTML>
				<g:HTMLPanel styleName="settingOtherOptionGroup">
					<g:RadioButton ui:field="radioButtonRegisterIndicatedProblemOn" name="GROUP_REGISTER_INDICATED_PROBLEM" styleName="settingOtherOption">オン</g:RadioButton>
					<g:RadioButton ui:field="radioButtonRegisterIndicatedProblemOff" name="GROUP_REGISTER_INDICATED_PROBLEM" styleName="settingOtherOption">オフ</g:RadioButton>
				</g:HTMLPanel>
			</g:HTMLPanel>
		</g:HTMLPanel>
	</g:HTMLPanel>
</ui:UiBinder> 
